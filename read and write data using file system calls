#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main() {
    int fd;
    char msg[] = "Hello World";
    char buf[20];

    fd = open("test.txt", O_CREAT | O_RDWR, 0644);
    write(fd, msg, sizeof(msg));
    lseek(fd, 0, SEEK_SET);
    read(fd, buf, sizeof(msg));

    printf("Data: %s\n", buf);
    close(fd);

    return 0;
}
