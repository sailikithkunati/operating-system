#include <stdio.h>

int main() {
    int p[] = {1, 2, 3, 4, 1}, f[3] = {-1, -1, -1};
    int i, j, k = 0, hit, fault = 0;

    for (i = 0; i < 5; i++) {
        hit = 0;
        for (j = 0; j < 3; j++)
            if (f[j] == p[i]) hit = 1;

        if (!hit) {
            f[k] = p[i];
            k = (k + 1) % 3;
            fault++;
        }
    }

    printf("Page Faults = %d", fault);
    return 0;
}
