#include <stdio.h>

#define MAX 5

int queue[MAX], front = -1, rear = -1;

void enqueue(int p) {
    if (rear == MAX - 1)
        printf("Ready Queue Full\n");
    else {
        if (front == -1)
            front = 0;
        queue[++rear] = p;
    }
}

void dequeue() {
    if (front == -1 || front > rear)
        printf("Ready Queue Empty\n");
    else
        printf("Process %d executed\n", queue[front++]);
}

void display() {
    int i;
    if (front == -1 || front > rear)
        printf("Ready Queue Empty\n");
    else {
        printf("Ready Queue: ");
        for (i = front; i <= rear; i++)
            printf("P%d ", queue[i]);
        printf("\n");
    }
}

int main() {
    enqueue(1);
    enqueue(2);
    enqueue(3);

    display();

    dequeue();

    display();

    return 0;
}
